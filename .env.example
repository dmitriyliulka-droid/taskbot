# Токен від @BotFather (обов'язково)
BOT_TOKEN=your_token_here

# Пароль для отримання прав керівника через /manager <пароль>
MANAGER_PASSWORD=admin123

# Час щоденного авто-звіту керівникам (24-год формат)
REPORT_HOUR=18
REPORT_MINUTE=0

# Час щоденного сповіщення про прострочені задачі підлеглим
OVERDUE_HOUR=9
OVERDUE_MINUTE=0
